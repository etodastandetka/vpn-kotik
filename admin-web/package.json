{
  "name": "vpn-admin-web",
  "private": true,
  "scripts": {
    "clean": "node -e \"const fs=require('fs');const p='.next';if(fs.existsSync(p))fs.rmSync(p,{recursive:true,force:true});\"",
    "dev": "next dev -p 3000",
    "dev:clean": "npm run clean && next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^14.2.23",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  }
}
