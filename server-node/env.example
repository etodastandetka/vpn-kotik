# Скопируйте в .env на сервере (рядом со скриптами) и поправьте под себя.
# cp env.example .env && nano .env

# --- SSH / файрвол ---
SSH_PORT=22

# Порты, которые откроет UFW (через запятую). 443/80 — часто нужны для TLS и веб.
# Панель 3x-ui по умолчанию слушает 2053 (см. документацию панели после установки).
OPEN_TCP_PORTS=22,80,443,2053

# --- Установка панели (Xray) ---
# true — в конце запустится официальный установщик 3x-ui (интерактив: логин/пароль админки).
INSTALL_3XUI=true

# Ветка/репо установщика (менять только если знаете зачем)
XUI_INSTALL_URL=https://raw.githubusercontent.com/mhsanaei/3x-ui/master/install.sh
