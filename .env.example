# Copy to .env and fill in values.

# Telegram bot from @BotFather
BOT_TOKEN=

# PostgreSQL (asyncpg). Docker Compose overrides this for api/bot services.
DATABASE_URL=postgresql+asyncpg://vpn:vpn@localhost:5432/vpn

# Cardlink — API token и shop_id из личного кабинета (магазин после модерации)
CARDLINK_TOKEN=
CARDLINK_SHOP_ID=
CARDLINK_BASE_URL=https://cardlink.link

# Crypto Pay: create app in @CryptoBot, get API token
CRYPTO_PAY_TOKEN=
# true = https://testnet-pay.crypt.bot
CRYPTO_PAY_USE_TESTNET=false

# Public base URL of the API (no trailing slash). Used to document webhook URL for Crypto Pay.
WEBHOOK_BASE_URL=https://your-domain.example
# Если пусто — для ссылки подписки Happ берётся WEBHOOK_BASE_URL. Иначе отдельный домен только под /sub/...
PUBLIC_API_BASE_URL=
# Path must match what you register in Crypto Pay webhook settings
CRYPTO_WEBHOOK_PATH=/webhooks/crypto-pay

# Cardlink Result URL в настройках магазина: {WEBHOOK_BASE_URL}{CARDLINK_WEBHOOK_PATH}
CARDLINK_WEBHOOK_PATH=/webhooks/cardlink

# Бонус пригласившему (дни), когда реферал впервые оплатил
REFERRAL_BONUS_DAYS=7

# Поддержка в боте: username без @ и опционально URL (сайт, правила)
SUPPORT_USERNAME=
SUPPORT_INFO_URL=

# Подписка для клиентов (после оплаты пишется в БД как config_stub).
# Вариант A — готовый subscription URL из 3x-ui (одна ссылка на всех или общий inbound):
# SUBSCRIPTION_STUB_TEMPLATE=https://panel.example.com:2053/xxx/sub/abc
# Вариант B — шаблон с плейсхолдерами, если панель отдаёт URL по шаблону:
# SUBSCRIPTION_STUB_TEMPLATE=https://panel.example.com/sub/{telegram_id}
# Пусто = заглушка и предупреждение в логах API (только для разработки).
SUBSCRIPTION_STUB_TEMPLATE=

# Веб-админка (Next.js) вызывает FastAPI с заголовком X-Admin-Key
ADMIN_API_KEY=
PROMETHEUS_BASE_URL=
PROMETHEUS_TIMEOUT_SEC=10
# JSON-массив: [{"id":"n1","name":"NL","instance":"1.2.3.4:9100","panel_health_url":"https://panel/login"}]
MONITOR_NODES_JSON=[]
MONITOR_CPU_WARN_PCT=85
MONITOR_MEM_WARN_PCT=90
MONITOR_DISK_WARN_PCT=90
MONITOR_PANEL_TIMEOUT_SEC=8
